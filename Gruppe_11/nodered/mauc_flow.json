    {
        "id": "fn_event",
        "type": "function",
        "z": "f1",
        "name": "Event -> Text",
        "func": "var e = msg.payload || {};\nvar t = new Date().toLocaleTimeString();\nvar line;\nswitch(e.event){\n  case 'start':  line = 'Spiel gestartet (' + e.game + ', ' + e.player + ')'; break;\n  case 'keks': line = 'Keks eingesammelt - Punkte ' + e.score + ', uebrig ' + e.left; break;\n  case 'ende':    line = 'Spielende: ' + e.score + ' Punkte in ' + e.time_s + ' s'; break;\n  case 'status':\n    var map = {\n      menu: 'Menü', running_maze: 'Labyrinth läuft',\n      running_field: 'Freie Fläche läuft', game_over: 'Spielende'\n    };\n    line = 'Status: ' + (map[e.value] || e.value);\n    break;\n  default:       line = JSON.stringify(e);\n}\nmsg.payload = t + '  ' + line;\nreturn msg;\n",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 480,
        "y": 660,
        "wires": [
            [
                "tpl_log"
            ]
        ]
    },
    {
        "id": "fn_rounds",
        "type": "function",
        "z": "f1",
        "name": "Runden zaehlen",
        "func": "if (msg.payload && msg.payload.event === 'end') {\n  var c = (flow.get('rounds') || 0) + 1;\n  flow.set('rounds', c);\n  return { payload: c };\n}\nreturn null;\n",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 480,
        "y": 720,
        "wires": [
            [
                "t_rounds"
            ]
        ]
    },
