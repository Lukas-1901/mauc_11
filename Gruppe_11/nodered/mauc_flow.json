        "id": "tpl_log",
        "type": "ui_template",
        "z": "f1",
        "group": "gEvents",
        "name": "Log",
        "order": 1,
        "width": 0,
        "height": 0,
        "format": "<div style=\"height:240px;overflow-y:auto;font-family:monospace;font-size:12px;line-height:1.5;\">\n  <div ng-repeat=\"l in lines track by $index\">{{l}}</div>\n</div>\n<script>\n(function(scope){\n  scope.lines = scope.lines || [];\n  scope.$watch('msg', function(m){\n    if(!m || m.payload === undefined) return;\n    scope.lines.unshift('' + m.payload);\n    if(scope.lines.length > 15) scope.lines.length = 15;\n  });\n})(scope);\n</script>\n",
